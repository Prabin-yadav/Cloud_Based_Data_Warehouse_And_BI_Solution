# Example configuration (safe to commit)

# ── AWS RDS PostgreSQL ───────────────────────────────────────────
RDS_HOST=your-db.rds.amazonaws.com
RDS_PORT=5432
RDS_DBNAME=zentrik_pharma_dw
RDS_USER=zentrik_admin
RDS_PASSWORD=YOUR_PASSWORD_HERE
RDS_SSLMODE=require
RDS_CONNECT_TIMEOUT=15

# ── AdventureWorks SQL Server (optional) ─────────────────────────
AW_SOURCE_SERVER=.\\SQLEXPRESS
AW_SOURCE_DATABASE=AdventureWorksDW2025
